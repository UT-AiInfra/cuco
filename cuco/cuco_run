#!/usr/bin/env python3
"""
CUCo workload runner CLI.

Usage:
    cuco_run gemm_allgather                          # 50 generations (default)
    cuco_run gemm_allgather --generations 100         # custom generation count
    cuco_run gemm_allgather -- --api lsa              # pass extra args to run_evo.py
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))


def main():
    parser = argparse.ArgumentParser(
        description="Run CUCo evolution for a workload.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  cuco_run gemm_allgather                    Run with 50 generations (default)
  cuco_run gemm_allgather --generations 100  Run with 100 generations
  cuco_run gemm_allgather -- --api lsa       Pass extra args to run_evo.py
""",
    )
    parser.add_argument(
        "workload",
        help="Workload name (directory under workloads/) or path to a workload directory.",
    )
    parser.add_argument(
        "--generations", type=int, default=50,
        help="Number of generations (default: 50).",
    )

    args, extra = parser.parse_known_args()

    from cuco.run_workload import run

    try:
        exit_code = run(
            workload_name=args.workload,
            num_generations=args.generations,
            extra_args=extra if extra else None,
        )
        sys.exit(exit_code)
    except FileNotFoundError as e:
        print(f"\n  Error: {e}\n", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
